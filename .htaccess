# JSL EMBALAGENS

Options -Indexes
RewriteEngine On

# HTTPS obrigatorio
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# WWW canonico
RewriteCond %{HTTP_HOST} ^jslembalagens\.com\.br$ [NC]
RewriteRule ^ https://www.jslembalagens.com.br%{REQUEST_URI} [R=301,L]

# Nao reescreve arquivos e pastas que existem de verdade
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rotas limpas
RewriteRule ^checkout-retorno$ /checkout-retorno.html [L]
RewriteRule ^produtos/([a-zA-Z0-9_-]+)$ /html/produto.html?produto=$1 [QSA,L]
RewriteRule ^produtos$ /html/produtos.html [L]
RewriteRule ^sobre$ /html/sobre.html [L]
RewriteRule ^contato$ /html/contato.html [L]
RewriteRule ^politicas$ /html/politicas.html [L]
RewriteRule ^carrinho$ /html/carrinho.html [L]
RewriteRule ^checkout$ /html/checkout.html [L]
RewriteRule ^perfil$ /html/perfil.html [L]
RewriteRule ^confirmar-email$ /html/confirmar-email.html [L]

# Bloquear pastas internas
RewriteRule ^(\.git|tmp|tools|supabase|node_modules)(/.*)?$ - [F,L]

# Arquivos sensiveis
<FilesMatch "\.(env|md|git|log|sql|bak|zip|tar)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files "robots.txt">
    Order Allow,Deny
    Allow from all
</Files>

<Files "sitemap.xml">
    Order Allow,Deny
    Allow from all
</Files>

AddType image/x-icon .ico
AddType image/svg+xml .svg

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/svg+xml         "access plus 1 year"
    ExpiresByType image/x-icon          "access plus 1 year"
    ExpiresByType text/css              "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    <FilesMatch "\.(html?)$">
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.(css|js)$">
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
